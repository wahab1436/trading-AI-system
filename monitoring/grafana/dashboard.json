{
  "dashboard": {
    "title": "Trading AI System - Production Dashboard",
    "uid": "trading-ai-dashboard",
    "version": 1,
    "timezone": "utc",
    "editable": true,
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "tags": ["trading", "ai", "forex", "production"],
    "description": "Real-time monitoring dashboard for Trading AI System",
    
    "panels": [
      {
        "id": 1,
        "title": "Account Balance & Equity",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "trading_ai_balance{account_type=\"live\"}",
            "legendFormat": "Balance",
            "refId": "A"
          },
          {
            "expr": "trading_ai_equity{account_type=\"live\"}",
            "legendFormat": "Equity",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {"mode": "palette-classic"},
            "custom": {"lineInterpolation": "smooth"}
          }
        },
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      
      {
        "id": 2,
        "title": "Daily P&L",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "trading_ai_pnl_daily{symbol=\"XAUUSD\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {
              "mode": "thresholds",
              "thresholds": [
                {"value": 0, "color": "red"},
                {"value": 0, "color": "green"}
              ]
            }
          }
        }
      },
      
      {
        "id": 3,
        "title": "Drawdown",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "targets": [
          {
            "expr": "trading_ai_drawdown_percent{symbol=\"XAUUSD\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      
      {
        "id": 4,
        "title": "Win Rate (Last 100 Trades)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
        "targets": [
          {
            "expr": "trading_ai_win_rate{period=\"100_trades\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "thresholds",
              "thresholds": [
                {"value": 40, "color": "red"},
                {"value": 50, "color": "yellow"},
                {"value": 55, "color": "green"}
              ]
            }
          }
        }
      },
      
      {
        "id": 5,
        "title": "Profit Factor (Weekly)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "trading_ai_profit_factor{period=\"week\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "yellow"},
                {"value": 1.4, "color": "green"}
              ]
            }
          }
        }
      },
      
      {
        "id": 6,
        "title": "Sharpe Ratio",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 4},
        "targets": [
          {
            "expr": "trading_ai_sharpe_ratio{period=\"month\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "yellow"},
                {"value": 1.5, "color": "green"}
              ]
            }
          }
        }
      },
      
      {
        "id": 7,
        "title": "Kill Switch",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 4},
        "targets": [
          {
            "expr": "trading_ai_kill_switch_active",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bool",
            "color": {
              "mode": "thresholds",
              "thresholds": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            },
            "mappings": [
              {"value": 0, "text": "INACTIVE", "color": "green"},
              {"value": 1, "text": "ACTIVE", "color": "red"}
            ]
          }
        }
      },
      
      {
        "id": 8,
        "title": "Open Positions",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "trading_ai_open_positions",
            "format": "table",
            "refId": "A"
          }
        ],
        "options": {
          "sortBy": [{"displayName": "Value", "desc": true}],
          "showHeader": true
        }
      },
      
      {
        "id": 9,
        "title": "Signal Distribution (Last Hour)",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "increase(trading_ai_signals_generated_total[1h])",
            "legendFormat": "{{signal_type}}",
            "refId": "A"
          }
        ],
        "options": {
          "displayLabels": ["name", "percent"],
          "legend": {"displayMode": "list", "placement": "right"},
          "pieType": "pie"
        }
      },
      
      {
        "id": 10,
        "title": "Model Prediction Confidence",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "trading_ai_prediction_confidence{model_version=\"champion\"}",
            "legendFormat": "{{signal_type}} Confidence",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 1,
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      
      {
        "id": 11,
        "title": "API Latency (p95)",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(trading_ai_api_latency_seconds_bucket[5m]))",
            "legendFormat": "{{endpoint}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      
      {
        "id": 12,
        "title": "Inference Latency",
        "type": "heatmap",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(trading_ai_inference_latency_seconds_bucket[5m])",
            "format": "heatmap",
            "refId": "A"
          }
        ],
        "options": {
          "calculate": true,
          "calculation": {"yBuckets": ["0.01", "0.025", "0.05", "0.1", "0.25", "0.5", "1"]}
        }
      },
      
      {
        "id": 13,
        "title": "System Health",
        "type": "status-history",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 16},
        "targets": [
          {
            "expr": "trading_ai_system_status",
            "legendFormat": "{{component}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "list", "placement": "right"},
          "showValue": "never"
        }
      },
      
      {
        "id": 14,
        "title": "Broker Connection Status",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 16},
        "targets": [
          {
            "expr": "trading_ai_broker_connection_status{broker=\"mt5\"}",
            "legendFormat": "MT5",
            "refId": "A"
          },
          {
            "expr": "trading_ai_broker_connection_status{broker=\"oanda\"}",
            "legendFormat": "OANDA",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bool",
            "mappings": [
              {"value": 0, "text": "DISCONNECTED", "color": "red"},
              {"value": 1, "text": "CONNECTED", "color": "green"}
            ]
          }
        }
      },
      
      {
        "id": 15,
        "title": "Error Rate (Last Hour)",
        "type": "bargauge",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "increase(trading_ai_errors_total[1h])",
            "legendFormat": "{{error_type}} ({{component}})",
            "refId": "A"
          }
        ],
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "showUnfilled": true
        }
      },
      
      {
        "id": 16,
        "title": "Data Quality",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 22},
        "targets": [
          {
            "expr": "trading_ai_data_lag_seconds{symbol=\"XAUUSD\"}",
            "legendFormat": "Data Lag ({{timeframe}})",
            "refId": "A"
          },
          {
            "expr": "trading_ai_data_gap_count{symbol=\"XAUUSD\"}",
            "legendFormat": "Gap Count ({{timeframe}})",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      
      {
        "id": 17,
        "title": "Concept Drift Monitor",
        "type": "table",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "trading_ai_psi_score",
            "format": "table",
            "refId": "A"
          },
          {
            "expr": "trading_ai_drift_detected",
            "format": "table",
            "refId": "B"
          }
        ],
        "options": {
          "sortBy": [{"displayName": "Value", "desc": true}],
          "showHeader": true,
          "cellOptions": {"type": "color-background", "mode": "gradient"}
        }
      },
      
      {
        "id": 18,
        "title": "Retraining Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 34},
        "targets": [
          {
            "expr": "trading_ai_retrain_success{model_type=\"fusion\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bool",
            "mappings": [
              {"value": 0, "text": "FAILED", "color": "red"},
              {"value": 1, "text": "SUCCESS", "color": "green"}
            ]
          }
        }
      },
      
      {
        "id": 19,
        "title": "Last Retrain Duration",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 34},
        "targets": [
          {
            "expr": "trading_ai_retrain_duration_seconds{model_type=\"fusion\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": {"mode": "thresholds", "thresholds": [
              {"value": 0, "color": "green"},
              {"value": 300, "color": "yellow"},
              {"value": 600, "color": "red"}
            ]}
          }
        }
      },
      
      {
        "id": 20,
        "title": "Trade History (Last 20 Trades)",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 38},
        "targets": [
          {
            "expr": "trading_ai_trades_total",
            "format": "table",
            "refId": "A"
          }
        ],
        "options": {
          "sortBy": [{"displayName": "Time", "desc": true}],
          "showHeader": true,
          "cellOptions": {"type": "auto"}
        }
      }
    ],
    
    "annotations": {
      "list": [
        {
          "name": "Model Retrain",
          "datasource": "Prometheus",
          "expr": "changes(trading_ai_last_retrain_timestamp[1d]) > 0",
          "iconColor": "blue",
          "titleFormat": "Model Retrained",
          "textFormat": "{{model_type}} retrained"
        },
        {
          "name": "Kill Switch",
          "datasource": "Prometheus",
          "expr": "changes(trading_ai_kill_switch_active[1h]) > 0 and trading_ai_kill_switch_active == 1",
          "iconColor": "red",
          "titleFormat": "Kill Switch Activated",
          "textFormat": "Trading stopped"
        },
        {
          "name": "Drift Detected",
          "datasource": "Prometheus",
          "expr": "changes(trading_ai_drift_detected[1h]) > 0 and trading_ai_drift_detected == 1",
          "iconColor": "orange",
          "titleFormat": "Concept Drift",
          "textFormat": "{{feature}} drifted"
        },
        {
          "name": "Error Spike",
          "datasource": "Prometheus",
          "expr": "increase(trading_ai_errors_total[5m]) > 10",
          "iconColor": "red",
          "titleFormat": "Error Spike",
          "textFormat": "{{error_type}} errors increased"
        }
      ]
    },
    
    "variables": [
      {
        "name": "symbol",
        "type": "query",
        "query": "label_values(trading_ai_pnl_total, symbol)",
        "refresh": 2,
        "current": {"value": "XAUUSD", "text": "XAUUSD"},
        "includeAll": false,
        "multi": false
      },
      {
        "name": "timeframe",
        "type": "interval",
        "query": "1m,5m,15m,1h,4h,1d",
        "current": {"value": "15m", "text": "15m"},
        "refresh": 2,
        "auto": false
      },
      {
        "name": "model_version",
        "type": "query",
        "query": "label_values(trading_ai_prediction_confidence, model_version)",
        "refresh": 2,
        "current": {"value": "champion", "text": "champion"},
        "includeAll": true
      }
    ],
    
    "links": [
      {
        "title": "Alert Rules",
        "url": "/alerting/list",
        "icon": "alert",
        "type": "link"
      },
      {
        "title": "MLflow",
        "url": "http://localhost:5000",
        "targetBlank": true,
        "icon": "external link",
        "type": "link"
      },
      {
        "title": "API Docs",
        "url": "/api/docs",
        "targetBlank": true,
        "icon": "doc",
        "type": "link"
      }
    ],
    
    "alerting": {
      "alertmanagers": ["http://localhost:9093"],
      "templates": [
        {
          "name": "trade_alert",
          "template": "{{ range .alerts }}\n**{{ .annotations.summary }}**\n{{ .annotations.description }}\n{{ end }}"
        }
      ]
    },
    
    "refreshIntervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    
    "schemaVersion": 36,
    "style": "dark"
  },
  
  "overwrite": true,
  "folderId": 0,
  "message": "Updated Trading AI Dashboard with comprehensive metrics"
}
