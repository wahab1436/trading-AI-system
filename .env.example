# Trading AI System - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# BROKER CONFIGURATION
# ============================================

# MT5 Configuration
MT5_SERVER=ICMarkets-Demo
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_TIMEOUT=30

# OANDA Configuration (Backup)
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_ENVIRONMENT=practice  # or live
OANDA_HOST=api-fxpractice.oanda.com

# ============================================
# API & SECURITY
# ============================================

# JWT Authentication
JWT_SECRET_KEY=your_super_secret_jwt_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API Rate Limiting
API_RATE_LIMIT=60  # requests per minute
API_BURST_LIMIT=10

# Encryption (for model artifacts)
ENCRYPTION_KEY=your_32_byte_aes_encryption_key

# ============================================
# DATA STORAGE
# ============================================

# DVC Remote Storage (S3)
DVC_REMOTE_TYPE=s3
DVC_REMOTE_URL=s3://trading-ai-data/
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=us-east-1

# Local Data Paths
DATA_RAW_PATH=data/raw/
DATA_PROCESSED_PATH=data/processed/
DATA_LABELS_PATH=data/labels/
DATA_IMAGES_PATH=data/images/
MODELS_PATH=models/

# ============================================
# MLOPS & TRACKING
# ============================================

# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=trading-ai-fusion

# Model Registry
MODEL_REGISTRY_PATH=models/registry/
CHAMPION_MODEL_TAG=champion
CHALLENGER_MODEL_TAG=challenger

# ============================================
# MONITORING & ALERTING
# ============================================

# Slack Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL=#trading-alerts

# Email Alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENT=trader@example.com

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your_grafana_api_key

# ============================================
# TRADING PARAMETERS
# ============================================

# Risk Management (override config files)
MAX_RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_CONCURRENT_TRADES=3
MAX_DRAWDOWN_PCT=0.10

# Position Sizing
MIN_LOT_SIZE=0.01
MAX_LOT_SIZE=1.00
DEFAULT_PIP_VALUE=10.0

# Trading Hours
TRADING_SESSION_START=8  # UTC hour
TRADING_SESSION_END=21   # UTC hour

# ============================================
# MODEL PARAMETERS
# ============================================

# CNN Model
CNN_ARCHITECTURE=efficientnet-b3
CNN_EMBEDDING_DIM=1536
CNN_DROPOUT=0.3
CNN_PRETRAINED=true

# Fusion Model (XGBoost)
XGB_N_ESTIMATORS=500
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.05
XGB_SUBSAMPLE=0.8

# PCA
PCA_COMPONENTS=128

# ============================================
# PERFORMANCE & SCALING
# ============================================

# Database (for trade journal)
DATABASE_URL=postgresql://user:password@localhost/trading_db
REDIS_URL=redis://localhost:6379/0

# Celery (for async tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # or text
LOG_FILE_PATH=logs/trading_system.log

# ============================================
# DEVELOPMENT
# ============================================

# Debug Mode
DEBUG=false
TESTING=false
PROFILE_MEMORY=false

# Synthetic Data Generation (for testing)
USE_SYNTHETIC_DATA=false
SYNTHETIC_DATA_START_DATE=2019-01-01
SYNTHETIC_DATA_END_DATE=2024-12-31

# ============================================
# SECURITY (NEVER COMMIT THESE)
# ============================================

# HashiCorp Vault (optional)
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=your_vault_token
VAULT_SECRET_PATH=secret/trading-ai

# AWS Secrets Manager (optional)
AWS_SECRETS_MANAGER_REGION=us-east-1
AWS_SECRETS_MANAGER_NAME=trading-ai/secrets
